{
  "root": true,
  "ignorePatterns": [
    "dist/"
  ],
  "extends": [
    "eslint:recommended"
  ],
  "overrides": [
    {
      "files": [
        "src/**/*.js"
      ],
      "env": {
        "browser": true,
        "es2021": true,
        "worker": true
      },
      "parserOptions": {
        "ecmaVersion": 2021,
        "sourceType": "module"
      },
      "globals": {
        "chrome": "readonly"
      }
    },
    {
      "files": [
        "scripts/**/*.js",
        "webpack.config.js"
      ],
      "env": {
        "es2021": true,
        "node": true
      },
      "parserOptions": {
        "ecmaVersion": 2021,
        "sourceType": "script"
      }
    }
  ]
}
