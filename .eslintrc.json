{
  "root": true,
  "ignorePatterns": [
    "dist/",
    "dist-firefox/"
  ],
  "extends": [
    "eslint:recommended"
  ],
  "overrides": [
    {
      "files": [
        "src/**/*.js"
      ],
      "env": {
        "browser": true,
        "es2021": true,
        "worker": true
      },
      "parserOptions": {
        "ecmaVersion": 2021,
        "sourceType": "module"
      },
      "globals": {
        "chrome": "readonly"
      }
    },
    {
      "files": [
      "src/**/*.mjs"
      ],
      "env": {
      "browser": true,
      "es2021": true,
      "worker": true
      },
      "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module"
      },
      "globals": {
      "chrome": "readonly"
      }
    },
    {
      "files": [
      "scripts/**/*.js",
      "webpack.config.js"
      ],
      "env": {
        "es2021": true,
        "node": true
      },
      "parserOptions": {
        "ecmaVersion": 2021,
        "sourceType": "script"
      }
    },
    {
      "files": [
        "scripts/**/*.mjs"
      ],
      "env": {
        "es2021": true,
        "node": true
      },
      "parserOptions": {
        "ecmaVersion": 2021,
        "sourceType": "module"
      }
    }
  ]
}
